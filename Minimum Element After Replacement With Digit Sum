class Solution: 
    def minElement(self, nums: List[int]) -> int:  
        min = float('inf') 
        for i in range(len(nums)): 
            num = nums[i]
            digitSum = 0

            while num > 0:
                digitSum += num % 10
                num //= 10

            if digitSum < min:
                min = digitSum

        return min        
